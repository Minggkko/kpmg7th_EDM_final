SUPABASE_JWT_SECRET=your-jwt-secret

# OpenAI
OPENAI_API_KEY=sk-...

# Upstage (Document OCR)
UPSTAGE_API_KEY=up_...

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
CONFIDENCE_THRESHOLD=0.85
